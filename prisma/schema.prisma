// UNISSACO - University Student Savings and Investment Cooperative
// Prisma schema (SQLite adapter; designed to map cleanly to PostgreSQL in production)

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// ────────────────────────────────────────────────────────────────────────────
// MODULE 1 + 2: Authentication & Member Management
// ────────────────────────────────────────────────────────────────────────────

model User {
    id            String  @id @default(cuid())
    email         String  @unique
    passwordHash  String
    // Role: MEMBER | ADMIN | SUPER_ADMIN
    role          String  @default("MEMBER")
    // Member status: PENDING | ACTIVE | SUSPENDED | CLOSED
    status        String  @default("PENDING")
    emailVerified Boolean @default(false)

    // Profile fields
    fullName       String?
    studentId      String?   @unique
    phone          String?
    program        String?
    yearOfStudy    String?
    gender         String?
    dateOfBirth    DateTime?
    address        String?
    nextOfKin      String?
    nextOfKinPhone String?
    avatarUrl      String?

    joinedAt     DateTime  @default(now())
    approvedAt   DateTime?
    approvedById String?
    suspendedAt  DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    savingsAccount          SavingsAccount?
    shareHoldings           ShareHolding?
    savingsTxns             SavingsTransaction[]
    shareTxns               ShareTransaction[]
    investments             InvestmentMember[]
    auditLogs               AuditLog[]
    loanApplications        LoanApplication[] // loans this user applied for
    loanApprovals           LoanApplication[]       @relation("LoanApprover") // loans this user approved
    loanRejections          LoanApplication[]       @relation("LoanRejecter") // loans this user rejected
    loanGuarantees          LoanGuarantor[]
    dividends               DividendPayout[]
    notifications           Notification[]
    notificationPreferences NotificationPreference?

    @@index([status])
    @@index([role])
}

// ────────────────────────────────────────────────────────────────────────────
// MODULE 3: Savings Management
// ────────────────────────────────────────────────────────────────────────────

model SavingsAccount {
    id              String   @id @default(cuid())
    userId          String   @unique
    user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    balance         Float    @default(0)
    // interest accrued over time (compound, configurable)
    interestAccrued Float    @default(0)
    createdAt       DateTime @default(now())
    updatedAt       DateTime @updatedAt

    transactions SavingsTransaction[]
}

model SavingsTransaction {
    id           String         @id @default(cuid())
    accountId    String
    account      SavingsAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
    userId       String
    user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
    // Type: DEPOSIT | WITHDRAWAL | ADJUSTMENT | INTEREST | DIVIDEND | LOAN_DISBURSEMENT | LOAN_REPAYMENT
    type         String
    amount       Float
    balanceAfter Float
    description  String
    reference    String         @unique
    // channel/method: MOBILE_MONEY | BANK | CASH | SYSTEM
    method       String         @default("SYSTEM")
    status       String         @default("COMPLETED") // COMPLETED | PENDING | REVERSED
    recordedById String?
    createdAt    DateTime       @default(now())

    @@index([userId])
    @@index([accountId])
    @@index([type])
    @@index([createdAt])
}

// ────────────────────────────────────────────────────────────────────────────
// MODULE 4: Share Management
// ────────────────────────────────────────────────────────────────────────────

model ShareHolding {
    id             String   @id @default(cuid())
    userId         String   @unique
    user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    numberOfShares Int      @default(0)
    totalValue     Float    @default(0)
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt

    transactions ShareTransaction[]
}

model ShareTransaction {
    id             String       @id @default(cuid())
    holdingId      String
    holding        ShareHolding @relation(fields: [holdingId], references: [id], onDelete: Cascade)
    userId         String
    user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
    // Type: BUY | SELL | ALLOTMENT
    type           String
    numberOfShares Int
    pricePerShare  Float
    totalAmount    Float
    sharesAfter    Int
    reference      String       @unique
    status         String       @default("COMPLETED")
    createdAt      DateTime     @default(now())

    @@index([userId])
    @@index([holdingId])
    @@index([createdAt])
}

// ────────────────────────────────────────────────────────────────────────────
// MODULE 5: Investments
// ────────────────────────────────────────────────────────────────────────────

model Investment {
    id             String    @id @default(cuid())
    name           String
    category       String // AGRICULTURE | STUDENT_VENTURE | FIXED_INCOME | REAL_ESTATE | OTHER
    description    String
    amountInvested Float
    expectedROI    Float     @default(0) // percentage
    actualProfit   Float     @default(0)
    // Status: PROPOSED | ACTIVE | MATURED | CLOSED | CANCELLED
    status         String    @default("PROPOSED")
    startDate      DateTime
    endDate        DateTime?
    imageUrl       String?
    createdBy      String?
    createdAt      DateTime  @default(now())
    updatedAt      DateTime  @updatedAt

    members InvestmentMember[]

    @@index([status])
    @@index([category])
}

model InvestmentMember {
    id                String     @id @default(cuid())
    investmentId      String
    investment        Investment @relation(fields: [investmentId], references: [id], onDelete: Cascade)
    userId            String
    user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
    amountContributed Float
    sharePct          Float      @default(0) // share of total investment
    expectedReturn    Float      @default(0)
    actualReturn      Float      @default(0)
    createdAt         DateTime   @default(now())
    updatedAt         DateTime   @updatedAt

    @@unique([investmentId, userId])
    @@index([userId])
}

// ────────────────────────────────────────────────────────────────────────────
// MODULE 6: Loans Management
// ────────────────────────────────────────────────────────────────────────────

model LoanProduct {
    id                 String   @id @default(cuid())
    name               String
    description        String
    minAmount          Float    @default(0)
    maxAmount          Float
    interestRate       Float // % per annum
    repaymentPeriod    Int // months
    processingFee      Float    @default(0) // percentage or flat
    latePaymentPenalty Float    @default(0) // % per month overdue
    requiresGuarantor  Boolean  @default(false)
    minGuarantors      Int      @default(0)
    // Status: ACTIVE | INACTIVE
    status             String   @default("ACTIVE")
    createdAt          DateTime @default(now())
    updatedAt          DateTime @updatedAt

    applications LoanApplication[]

    @@index([status])
}

model LoanApplication {
    id                 String      @id @default(cuid())
    userId             String
    user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
    productId          String
    product            LoanProduct @relation(fields: [productId], references: [id])
    // Application details
    amountApplied      Float
    amountApproved     Float?
    interestRate       Float // locked at approval time
    repaymentPeriod    Int // months, locked at approval
    monthlyInstallment Float?
    totalRepayable     Float?
    purpose            String
    // Status: PENDING | APPROVED | REJECTED | DISBURSED | CLOSED | DEFAULTED
    status             String      @default("PENDING")
    applicationDate    DateTime    @default(now())
    approvedAt         DateTime?
    approvedById       String?
    approvedBy         User?       @relation("LoanApprover", fields: [approvedById], references: [id])
    rejectionReason    String?
    rejectedAt         DateTime?
    rejectedById       String?
    rejectedBy         User?       @relation("LoanRejecter", fields: [rejectedById], references: [id])
    disbursedAt        DateTime?
    disbursedById      String?
    closedAt           DateTime?
    balance            Float       @default(0)
    createdAt          DateTime    @default(now())
    updatedAt          DateTime    @updatedAt

    repayments LoanRepayment[]
    guarantors LoanGuarantor[]

    @@index([userId])
    @@index([status])
    @@index([productId])
}

model LoanRepayment {
    id               String          @id @default(cuid())
    loanId           String
    loan             LoanApplication @relation(fields: [loanId], references: [id], onDelete: Cascade)
    amount           Float
    principalPortion Float           @default(0)
    interestPortion  Float           @default(0)
    balanceAfter     Float
    dueDate          DateTime
    paidDate         DateTime?
    // Status: PENDING | PAID | PARTIAL | OVERDUE
    status           String          @default("PENDING")
    reference        String          @unique
    method           String          @default("SYSTEM")
    recordedById     String?
    createdAt        DateTime        @default(now())

    @@index([loanId])
    @@index([status])
    @@index([dueDate])
}

model LoanGuarantor {
    id               String          @id @default(cuid())
    loanId           String
    loan             LoanApplication @relation(fields: [loanId], references: [id], onDelete: Cascade)
    userId           String
    user             User            @relation(fields: [userId], references: [id])
    amountGuaranteed Float
    // Status: PENDING | APPROVED | REJECTED
    status           String          @default("PENDING")
    approvedAt       DateTime?
    createdAt        DateTime        @default(now())

    @@unique([loanId, userId])
    @@index([userId])
}

// ────────────────────────────────────────────────────────────────────────────
// MODULE 7: Dividend Management
// ────────────────────────────────────────────────────────────────────────────

model DividendDeclaration {
    id             String    @id @default(cuid())
    // Period: e.g. "2025-Q1" for first quarter, "2025-H1" for half-year, "2025" for annual
    period         String    @unique
    label          String // e.g. "First Quarter 2025 Dividend"
    totalAmount    Float // total pool declared
    ratePerShare   Float // MWK per share
    eligibleShares Int // total eligible shares at declaration time
    status         String    @default("DECLARED") // DECLARED | PAID_OUT | CANCELLED
    declaredById   String?
    declaredAt     DateTime  @default(now())
    paidOutAt      DateTime?
    notes          String?
    createdAt      DateTime  @default(now())
    updatedAt      DateTime  @updatedAt

    payouts DividendPayout[]

    @@index([status])
    @@index([period])
}

model DividendPayout {
    id               String              @id @default(cuid())
    declarationId    String
    declaration      DividendDeclaration @relation(fields: [declarationId], references: [id], onDelete: Cascade)
    userId           String
    user             User                @relation(fields: [userId], references: [id])
    numberOfShares   Int // shares held at declaration
    amountPerShare   Float // rate locked at declaration
    totalAmount      Float // numberOfShares * amountPerShare
    deductedAtSource Float               @default(0) // e.g. withholding tax
    netAmount        Float // totalAmount - deductedAtSource
    status           String              @default("PENDING") // PENDING | PAID | CANCELLED
    paidAt           DateTime?
    reference        String?
    createdAt        DateTime            @default(now())

    @@unique([declarationId, userId])
    @@index([userId])
    @@index([declarationId])
    @@index([status])
}

// ────────────────────────────────────────────────────────────────────────────
// MODULE 8: In-App Notifications
// ────────────────────────────────────────────────────────────────────────────

model Notification {
    id        String    @id @default(cuid())
    userId    String
    user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    // Type: DEPOSIT | WITHDRAWAL | SHARE_PURCHASE | LOAN_APPLIED | LOAN_APPROVED | LOAN_REJECTED | LOAN_DISBURSED | LOAN_REPAYMENT | DIVIDEND | MEMBER_APPROVED | MEMBER_SUSPENDED | MEMBER_CLOSED | GUARANTOR_REQUEST | GUARANTOR_CONFIRMED | SYSTEM
    type      String
    title     String
    message   String
    // Link to navigate to when clicked (e.g. "/savings", "/loans")
    link      String?
    // Related entity reference for grouping
    entityId  String?
    read      Boolean   @default(false)
    readAt    DateTime?
    createdAt DateTime  @default(now())

    @@index([userId, read])
    @@index([userId, createdAt])
    @@index([type])
}

model NotificationPreference {
    id                 String   @id @default(cuid())
    userId             String   @unique
    user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    deposit            Boolean  @default(true)
    withdrawal         Boolean  @default(true)
    sharePurchase      Boolean  @default(true)
    loanApplied        Boolean  @default(true)
    loanApproved       Boolean  @default(true)
    loanRejected       Boolean  @default(true)
    loanDisbursed      Boolean  @default(true)
    loanRepayment      Boolean  @default(true)
    loanDueReminder    Boolean  @default(true)
    dividend           Boolean  @default(true)
    memberApproved     Boolean  @default(true)
    memberSuspended    Boolean  @default(true)
    memberClosed       Boolean  @default(true)
    guarantorRequest   Boolean  @default(true)
    guarantorConfirmed Boolean  @default(true)
    system             Boolean  @default(true)
    createdAt          DateTime @default(now())
    updatedAt          DateTime @updatedAt
}

// ────────────────────────────────────────────────────────────────────────────
// SYSTEM: Settings + Audit
// ────────────────────────────────────────────────────────────────────────────

model Setting {
    id        String   @id
    value     String
    // Common keys: SHARE_PRICE, SAVINGS_INTEREST_RATE, MIN_SAVINGS, DIVIDEND_RATE, DIVIDEND_TAX_RATE
    updatedAt DateTime @updatedAt
}

model AuditLog {
    id        String   @id @default(cuid())
    userId    String?
    user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
    action    String // e.g. LOGIN, DEPOSIT, SHARE_BUY, MEMBER_APPROVE, LOAN_APPLY, LOAN_APPROVE, LOAN_DISBURSE, LOAN_REPAY, DIVIDEND_DECLARE, DIVIDEND_PAYOUT
    entity    String // e.g. SavingsTransaction, User, LoanApplication, LoanRepayment, DividendDeclaration
    entityId  String?
    details   String
    ipAddress String?
    createdAt DateTime @default(now())

    @@index([userId])
    @@index([action])
    @@index([createdAt])
}
